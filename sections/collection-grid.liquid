  }
  

  
  .section-{{ section.id }} .product-carousel {
    display: flex;
    flex-wrap: nowrap;
    gap: 20px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding-bottom: 10px;
  }
  
  .section-{{ section.id }} .product-carousel .product-card {
    flex: 0 0 240px;
    min-width: 240px;
  }
  
