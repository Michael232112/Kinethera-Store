<section class="custom-hero">
  <div class="custom-hero__container">
    <div class="custom-hero__flex custom-hero__flex--image-{{ section.settings.image_position }}">
      <!-- Product Image -->
      <div class="custom-hero__image-wrapper">
        {% if section.settings.hero_video != blank %}
          <video
            class="custom-hero__video"
            autoplay
            muted
            loop
            playsinline
            poster="{{ section.settings.hero_image | image_url: width: 800 }}"
          >
            <source src="{{ section.settings.hero_video.sources[1].url }}" type="video/mp4">
          </video>
        {% elsif section.settings.hero_image %}
          {{
            section.settings.hero_image
            | image_url: width: 800
            | image_tag: class: 'custom-hero__image', loading: 'lazy', alt: section.settings.heading
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'custom-hero__image placeholder' }}
        {% endif %}
      </div>

      <!-- Product Content -->
      <div class="custom-hero__content">
        <div class="custom-hero__content-wrapper">
        {% if section.settings.show_badge and section.settings.badge_text != blank %}
          <div class="custom-hero__badge-wrapper">
            <div class="custom-hero__badge">{{ section.settings.badge_text }}</div>
          </div>
        {% endif %}

        {% if section.settings.show_rating %}
          <div class="custom-hero__rating-wrapper">
            <div class="custom-hero__rating-container">
              {% if section.settings.profile_image_1 != blank
                or section.settings.profile_image_2 != blank
                or section.settings.profile_image_3 != blank
              %}
                <div class="custom-hero__profile-images">
                  {% if section.settings.profile_image_1 %}
                    {{
                      section.settings.profile_image_1
                      | image_url: width: 24, height: 24
                      | image_tag: class: 'custom-hero__profile-image', loading: 'lazy', alt: 'Profile Image'
                    }}
                  {% endif %}
                  {% if section.settings.profile_image_2 %}
                    {{
                      section.settings.profile_image_2
                      | image_url: width: 24, height: 24
                      | image_tag: class: 'custom-hero__profile-image', loading: 'lazy', alt: 'Profile Image'
                    }}
                  {% endif %}
                  {% if section.settings.profile_image_3 %}
                    {{
                      section.settings.profile_image_3
                      | image_url: width: 24, height: 24
                      | image_tag: class: 'custom-hero__profile-image', loading: 'lazy', alt: 'Profile Image'
                    }}
                  {% endif %}
                </div>
              {% endif %}
              <div class="custom-hero__rating-stars">
                {% if section.settings.use_theme_colors %}
                  {% comment %} Show 5 full stars when theme colors are on {% endcomment %}
                  {% for i in (1..5) %}
                    {% render 'icons', icon: 'custom_hero_rating' %}
                  {% endfor %}
                {% else %}
                  {% comment %} Show 5 full stars when theme colors are off {% endcomment %}
                  {% for i in (1..5) %}
                    {% render 'icons', icon: 'custom_hero_rating' %}
                  {% endfor %}
                {% endif %}
              </div>
              <div class="custom-hero__rating-text">{{ section.settings.rating_text }}</div>
            </div>
          </div>
        {% endif %}

        <h2 class="custom-hero__title section-heading">
          {%- if section.settings.heading != blank -%}
            {{ section.settings.heading }}
          {%- endif -%}
          {%- if section.settings.heading_accent != blank -%}
            <span class="section-accent-text accent-font">{{ section.settings.heading_accent }}</span>
          {%- endif -%}
        </h2>

        {% if section.settings.subtitle != blank %}
          <div class="custom-hero__subtitle">{{ section.settings.subtitle }}</div>
        {% endif %}

        {% if section.settings.show_benefits %}
          <div class="custom-hero__benefits{% if section.settings.benefits_flex_layout %} flex-layout{% endif %}">
          {% if section.settings.benefit_1_text != blank %}
            <div class="custom-hero__benefit-item">
              <span class="custom-hero__benefit-icon">
                {% case section.settings.benefit_1_icon %}
                  {% when 'check' %}
                    {{ checkmark_icon }}
                  {% when 'badge_check' %}
                    {{ badge_checkmark_icon }}
                  {% when 'circle_check' %}
                    {{ circle_checkmark_icon }}
                  {% when 'filled_circle_check' %}
                    {{ filled_circle_checkmark_icon }}
                  {% when 'check_mark' %}
                    {{ check_icon }}
                  {% when 'custom' %}
                    {{ section.settings.benefit_1_custom_svg }}
                {% endcase %}
              </span>
              <span>{{ section.settings.benefit_1_text }}</span>
            </div>
          {% endif %}

          {% if section.settings.benefit_2_text != blank %}
            <div class="custom-hero__benefit-item">
              <span class="custom-hero__benefit-icon">
                {% case section.settings.benefit_2_icon %}
                  {% when 'check' %}
                    {{ checkmark_icon }}
                  {% when 'badge_check' %}
                    {{ badge_checkmark_icon }}
                  {% when 'circle_check' %}
                    {{ circle_checkmark_icon }}
                  {% when 'filled_circle_check' %}
                    {{ filled_circle_checkmark_icon }}
                  {% when 'check_mark' %}
                    {{ check_icon }}
                  {% when 'custom' %}
                    {{ section.settings.benefit_2_custom_svg }}
                {% endcase %}
              </span>
              <span>{{ section.settings.benefit_2_text }}</span>
            </div>
          {% endif %}

          {% if section.settings.benefit_3_text != blank %}
            <div class="custom-hero__benefit-item">
              <span class="custom-hero__benefit-icon">
                {% case section.settings.benefit_3_icon %}
                  {% when 'check' %}
                    {{ checkmark_icon }}
                  {% when 'badge_check' %}
                    {{ badge_checkmark_icon }}
                  {% when 'circle_check' %}
                    {{ circle_checkmark_icon }}
                  {% when 'filled_circle_check' %}
                    {{ filled_circle_checkmark_icon }}
                  {% when 'check_mark' %}
                    {{ check_icon }}
                  {% when 'custom' %}
                    {{ section.settings.benefit_3_custom_svg }}
                {% endcase %}
              </span>
              <span>{{ section.settings.benefit_3_text }}</span>
            </div>
          {% endif %}
          </div>
        {% endif %}

        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="theme-button custom-hero__button">
            {{- section.settings.button_text -}}
          </a>
        {% endif %}

        {% if section.settings.show_guarantee %}
          <div class="custom-hero__guarantee">
                            <span class="custom-hero__guarantee-icon">
                  {% if section.settings.use_custom_guarantee_svg and section.settings.custom_guarantee_svg != blank %}
                    {{ section.settings.custom_guarantee_svg }}
                  {% else %}
                    {{ guarantee_icon }}
                  {% endif %}
                </span>
            <span class="custom-hero__guarantee-text">{{ section.settings.guarantee_text }}</span>
          </div>
        {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>


{% if section.settings.fit_image_to_height %}
  <script>
document.addEventListener('DOMContentLoaded', function() {
  const setSquareImageHeight = () => {
    const heroSection = document.querySelector('.custom-hero');
    if (!heroSection) return;
    
    const contentElement = heroSection.querySelector('.custom-hero__content');
    const imageWrapper = heroSection.querySelector('.custom-hero__image-wrapper');
    
    if (window.innerWidth > 768) {
      // On desktop: Make image wrapper same height as content
      const contentHeight = contentElement.offsetHeight;
      imageWrapper.style.height = `${contentHeight}px`;
      
      // Adjust aspect ratio
      if (contentHeight > 0) {
        imageWrapper.style.aspectRatio = 'auto';
      }
    } else {
      // On mobile: Set to a square aspect ratio
      imageWrapper.style.height = 'auto';
      imageWrapper.style.aspectRatio = '1';
    }
  };
  
  // Run on load and resize
  setSquareImageHeight();
  window.addEventListener('resize', setSquareImageHeight);
  
  // Also run after a short delay to handle any dynamic content loading
  setTimeout(setSquareImageHeight, 500);
});
  </script>
{% endif %}
