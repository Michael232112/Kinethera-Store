{% comment %} Google Fonts for accent text customization {% endcomment %}
{% unless section.settings.use_global_accent_typography %}
  {% if section.settings.accent_font_family != 'inherit' and section.settings.accent_font_family != 'serif' %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {% case section.settings.accent_font_family %}
      {% when 'Georgia Pro' %}
        <link href="https://fonts.googleapis.com/css2?family=Georgia+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
      {% when 'Bodoni Moda' %}
        <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;0,6..96,700;0,6..96,800;1,6..96,400;1,6..96,500;1,6..96,600;1,6..96,700;1,6..96,800&display=swap" rel="stylesheet">
      {% when 'Instrument Serif' %}
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
      {% when 'DM Serif Text' %}
        <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Text:ital@0;1&display=swap" rel="stylesheet">
      {% when 'Nothing You Could Do' %}
        <link href="https://fonts.googleapis.com/css2?family=Nothing+You+Could+Do&display=swap" rel="stylesheet">
    {% endcase %}
  {% endif %}
{% endunless %}

{{ 'hero.css' | asset_url | stylesheet_tag }}
{% style %}
    .custom-hero {
      {% if section.settings.use_theme_colors %}
        {% if settings.global_section_use_gradient_background %}
          background: {{ settings.global_section_gradient_background }};
        {% else %}
          background-color: {{ settings.global_section_background_color }};
        {% endif %}
      {% elsif section.settings.enable_gradient %}
        background: {{ section.settings.section_gradient_background }};
      {% else %}
        background-color: {{ section.settings.section_bg }};
      {% endif %}
      padding: {{ section.settings.section_padding_vertical }}px {{ section.settings.section_padding_horizontal }}px;
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    @media screen and (max-width: 768px) {
      .custom-hero {
        padding: {{ section.settings.section_padding_vertical_mobile }}px {{ section.settings.section_padding_horizontal_mobile }}px;
      }
    }

    .custom-hero__container {
      {% if section.settings.contain_section %}
        max-width: {{ section.settings.container_max_width }}px;
        margin: 0 auto;
        {% if section.settings.fit_image_to_height %}
          /* When full width image is enabled, only apply vertical padding to container */
          padding: {{ section.settings.container_padding_top }}px 0 {{ section.settings.container_padding_bottom }}px 0;
        {% else %}
          padding: {{ section.settings.container_padding_top }}px {{ section.settings.container_padding_right }}px {{ section.settings.container_padding_bottom }}px {{ section.settings.container_padding_left }}px;
        {% endif %}
        border-radius: {{ section.settings.border_radius }}px;
        {% if section.settings.enable_container_gradient %}
          background: {{ section.settings.container_gradient_background }};
        {% else %}
          background-color: {{ section.settings.container_bg_color }};
        {% endif %}
        {% if section.settings.enable_border %}
          border: {{ section.settings.border_width }}px {{ section.settings.border_style }} {{ section.settings.border_color }};
        {% endif %}
        {% if section.settings.enable_shadow %}
          box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        {% endif %}
        {% if section.settings.fit_image_to_height %}
          overflow: hidden;
        {% endif %}
      {% endif %}
    }

    @media screen and (max-width: 768px) {
      .custom-hero__container {
        {% if section.settings.contain_section %}
          {% if section.settings.fit_image_to_height %}
            /* When full width image is enabled, only apply vertical padding to container on mobile */
            padding: {{ section.settings.container_padding_top_mobile }}px 0 {{ section.settings.container_padding_bottom_mobile }}px 0;
          {% else %}
            padding: {{ section.settings.container_padding_top_mobile }}px {{ section.settings.container_padding_right_mobile }}px {{ section.settings.container_padding_bottom_mobile }}px {{ section.settings.container_padding_left_mobile }}px;
          {% endif %}
        {% endif %}
      }
    }

    .custom-hero__flex {
      align-items: {% if section.settings.fit_image_to_height %}stretch{% else %}center{% endif %};
      gap: {% if section.settings.fit_image_to_height %}0{% else %}40px{% endif %};
      {% if section.settings.fit_image_to_height and section.settings.contain_section %}
        /* When full width image is enabled with container, extend flex to full width */
        margin: 0 -{{ section.settings.container_padding_left }}px;
        width: calc(100% + {{ section.settings.container_padding_left | plus: section.settings.container_padding_right }}px);
      {% endif %}
    }

    @media screen and (max-width: 768px) {
      .custom-hero__flex {
        {% if section.settings.fit_image_to_height and section.settings.contain_section %}
          /* Mobile: Don't extend beyond container boundaries to prevent image cutoff */
          margin: 0;
          width: 100%;
          flex-direction: column;
        {% endif %}
      }
    }

    {% if section.settings.fit_image_to_height %}
      .custom-hero__image-wrapper {
        padding: 0;
        overflow: hidden;
        {% if section.settings.contain_section %}
          /* When container is enabled, image wrapper takes full width */
          flex: 1;
        {% endif %}
      }
      
      @media screen and (max-width: 768px) {
        .custom-hero__image-wrapper {
          {% if section.settings.contain_section %}
            /* Mobile: Ensure image stays within container boundaries */
            width: 100%;
            max-width: 100%;
            flex: none;
          {% endif %}
        }
      }
    {% endif %}

    .custom-hero__image {
      border-radius: {% if section.settings.fit_image_to_height %}0{% else %}8px{% endif %};
      {% if section.settings.fit_image_to_height %}
        height: 100%;
        object-fit: cover;
        width: 100%;
      {% endif %}
    }

    .custom-hero__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: {% if section.settings.fit_image_to_height %}0{% else %}8px{% endif %};
    }

    /* Custom SVG styling for benefit icons */
    .custom-hero__benefit-icon svg {
      width: {{ section.settings.benefit_icon_size }}px !important;
      height: {{ section.settings.benefit_icon_size }}px !important;
      fill: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.benefit_icon_color }}{% endif %};
    }

    /* Custom SVG styling for guarantee icon */
    .custom-hero__guarantee-icon svg {
      width: {{ section.settings.guarantee_icon_size }}px !important;
      height: {{ section.settings.guarantee_icon_size }}px !important;
      fill: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.benefit_icon_color }}{% endif %};
    }

    {% if section.settings.enable_image_fade_mask %}
      .custom-hero__image-wrapper {
        {% if section.settings.image_position == 'left' %}
          -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0) 0%, rgba(0,0,0,0.1) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,1) 50%);
          mask-image: linear-gradient(to left, rgba(0,0,0,0) 0%, rgba(0,0,0,0.1) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,1) 50%);
        {% else %}
          -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0) 0%, rgba(0,0,0,0.1) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,1) 50%);
          mask-image: linear-gradient(to right, rgba(0,0,0,0) 0%, rgba(0,0,0,0.1) 10%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,1) 50%);
        {% endif %}
      }

      @media screen and (max-width: 768px) {
        .custom-hero__image-wrapper {
          -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
          mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
        }
      }
    {% endif %}

    .custom-hero__content {
      {% if section.settings.fit_image_to_height and section.settings.contain_section %}
        /* When full width image is enabled with container, restore content padding */
        padding: {{ section.settings.content_padding_vertical | plus: 40 }}px {{ section.settings.container_padding_left | plus: section.settings.content_padding_horizontal | plus: 40 }}px {{ section.settings.content_padding_vertical | plus: 40 }}px {{ section.settings.container_padding_right | plus: section.settings.content_padding_horizontal | plus: 40 }}px !important;
      {% elsif section.settings.fit_image_to_height %}
        padding: {{ section.settings.content_padding_vertical | plus: 40 }}px {{ section.settings.content_padding_horizontal | plus: 40 }}px !important;
      {% else %}
        padding: {{ section.settings.content_padding_vertical }}px {{ section.settings.content_padding_horizontal }}px !important;
      {% endif %}
      text-align: {{ section.settings.desktop_content_alignment }};
    }

    .custom-hero__content-wrapper {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: {% if section.settings.desktop_content_alignment == 'center' %}center{% elsif section.settings.desktop_content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
      min-height: 100%;
      gap: 0;
    }

    /* Prevent flexbox from interfering with natural margins and spacing */
    .custom-hero__content-wrapper > * {
      flex-shrink: 0;
    }

    /* Ensure all spacing elements work properly in flexbox */
    .custom-hero__content-wrapper .custom-hero__badge-wrapper,
    .custom-hero__content-wrapper .custom-hero__rating-wrapper,
    .custom-hero__content-wrapper .custom-hero__benefits,
    .custom-hero__content-wrapper .custom-hero__button,
    .custom-hero__content-wrapper .custom-hero__guarantee {
      flex-shrink: 0;
    }

    /* Ensure spacing settings work properly within flexbox wrapper */
    .custom-hero__content-wrapper .custom-hero__title {
      margin-bottom: {{ section.settings.header_margin_bottom | default: 15 }}px !important;
    }

    .custom-hero__content-wrapper .custom-hero__subtitle {
      margin-top: {{ section.settings.subtitle_margin_top }}px !important;
      margin-bottom: {{ section.settings.subtitle_margin_bottom }}px !important;
    }

    /* Reset paragraph margins in content wrapper subtitle */
    .custom-hero__content-wrapper .custom-hero__subtitle p {
      margin: 0 !important;
      padding: 0 !important;
    }

    @media screen and (max-width: 768px) {
      .custom-hero__content {
        {% if section.settings.fit_image_to_height and section.settings.contain_section %}
          /* Mobile content padding with container */
          padding: {{ section.settings.content_padding_mobile }}px {{ section.settings.container_padding_left_mobile | plus: section.settings.content_padding_mobile }}px {{ section.settings.content_padding_mobile }}px {{ section.settings.container_padding_right_mobile | plus: section.settings.content_padding_mobile }}px !important;
        {% else %}
          padding: {{ section.settings.content_padding_mobile }}px !important;
        {% endif %}
        text-align: {{ section.settings.mobile_content_alignment }};
      }
      
      .custom-hero__content-wrapper {
        align-items: {% if section.settings.mobile_content_alignment == 'center' %}center{% elsif section.settings.mobile_content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
      }

      /* Mobile spacing fixes for flexbox wrapper */
      .custom-hero__content-wrapper .custom-hero__title {
        margin-bottom: {{ section.settings.header_margin_bottom_mobile | default: 15 }}px !important;
      }

      .custom-hero__content-wrapper .custom-hero__subtitle {
        margin-top: {{ section.settings.subtitle_margin_top_mobile }}px !important;
        margin-bottom: {{ section.settings.subtitle_margin_bottom_mobile }}px !important;
      }

      /* Reset paragraph margins in content wrapper subtitle on mobile */
      .custom-hero__content-wrapper .custom-hero__subtitle p {
        margin: 0 !important;
        padding: 0 !important;
      }
    }

    {% if section.settings.enable_image_fade_mask %}
      @media screen and (max-width: 768px) {
        .custom-hero__image-wrapper {
          -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
          mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
        }
      }
    {% endif %}

    .custom-hero .custom-hero__badge,
    section.custom-hero .custom-hero__badge,
    .custom-hero .custom-hero__badge-wrapper .custom-hero__badge {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.badge_text_color }}{% endif %};
      background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_2_color }}{% else %}{{ section.settings.badge_bg }}{% endif %};
      font-size: {{ section.settings.badge_font_size }}px !important;
    }

    .custom-hero .custom-hero__rating-stars {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color }}{% endif %};
      font-size: {{ section.settings.rating_stars_size }}px !important;
      --hero-star-size: {{ section.settings.rating_stars_size }}px;
    }

    .custom-hero .hero-star-icon {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color }}{% endif %};
      fill: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color }}{% endif %};
      width: {{ section.settings.rating_stars_size }}px !important;
      height: {{ section.settings.rating_stars_size }}px !important;
    }
    
    .custom-hero .custom-hero__rating-stars svg {
      width: {{ section.settings.rating_stars_size }}px !important;
      height: {{ section.settings.rating_stars_size }}px !important;
      display: inline-block;
    }

    .custom-hero .custom-hero__rating-text {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.rating_text_color }}{% endif %};
      font-size: {{ section.settings.rating_text_size }}px !important;
      display: inline-block;
      letter-spacing: var(--letter-spacing-body);
      margin: 0 2px;
      vertical-align: middle;
    }

    .custom-hero .custom-hero__star {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color }}{% endif %};
    }

    .custom-hero .custom-hero__title {
      font-family: var(--font-heading-family);
      font-weight: var(--font-weight-bold);
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.heading_color }}{% endif %};
      font-size: {{ section.settings.heading_size }}px;
      line-height: {{ section.settings.heading_line_height }};
      letter-spacing: var(--letter-spacing-heading);
      /* Ensure proper text flow and prevent cutoff */
      overflow: visible;
      word-wrap: break-word;
      overflow-wrap: break-word;
      margin-bottom: {{ section.settings.header_margin_bottom | default: 15 }}px;
    }

    .custom-hero .custom-hero__subtitle,
    section.custom-hero .custom-hero__subtitle,
    .custom-hero .custom-hero__content .custom-hero__subtitle,
    .custom-hero__container .custom-hero__content .custom-hero__subtitle {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.subtitle_color }}{% endif %} !important;
      font-size: {{ section.settings.subtitle_font_size }}px !important;
      line-height: {{ section.settings.subtitle_line_height }}em !important;
      letter-spacing: var(--letter-spacing-body) !important;
      margin-top: {{ section.settings.subtitle_margin_top }}px !important;
      margin-bottom: {{ section.settings.subtitle_margin_bottom }}px !important;
      word-wrap: break-word !important;
      overflow-wrap: break-word !important;
    }

    /* Reset paragraph margins within subtitle to prevent double margins from rich text */
    .custom-hero .custom-hero__subtitle p,
    section.custom-hero .custom-hero__subtitle p,
    .custom-hero .custom-hero__content .custom-hero__subtitle p,
    .custom-hero__container .custom-hero__content .custom-hero__subtitle p {
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Enhanced accent text styling */
    .custom-hero .section-accent-text,
    .new-hero-accent-text,
    .custom-hero .global-accent-text,
    .custom-hero .custom-accent-text {
      {% if section.settings.use_global_accent_typography %}
        /* Use Global Accent Typography */
        font-family: var(--font-accent-family) !important;
        font-style: var(--font-accent-style) !important;
        font-weight: var(--font-accent-weight) !important;
        letter-spacing: var(--font-accent-letter-spacing) !important;
        text-transform: var(--font-accent-text-transform) !important;
        font-style: var(--font-accent-style) !important;
      {% else %}
        /* Use Section-Specific Accent Typography */
        {%- assign accent_font_family_value = 'var(--font-heading-family)' -%}
      {% if section.settings.accent_font_family != 'inherit' %}
          {% case section.settings.accent_font_family %}
            {% when 'serif' %}
          font-family: serif !important;
            {% when 'Georgia Pro' %}
          font-family: 'Georgia Pro', Georgia, serif !important;
            {% when 'Bodoni Moda' %}
          font-family: 'Bodoni Moda', Georgia, serif !important;
            {% when 'Instrument Serif' %}
              font-family: 'Instrument Serif', Georgia, serif !important;
            {% when 'DM Serif Text' %}
              font-family: 'DM Serif Text', Georgia, serif !important;
            {% when 'Nothing You Could Do' %}
              font-family: 'Nothing You Could Do', cursive !important;
          {% endcase %}
      {% endif %}
      {% if section.settings.accent_font_style != 'normal' %}
        font-style: {{ section.settings.accent_font_style }} !important;
      {% endif %}
      {% if section.settings.accent_font_weight != 'inherit' %}
        font-weight: {{ section.settings.accent_font_weight }} !important;
        {% endif %}
      {% endif %}
      margin-left: {{ section.settings.accent_text_margin }}px !important;
      padding-right: 4px !important;
      /* Fix for multi-line text wrapping */
      display: inline !important;
      line-height: inherit !important;
      word-wrap: break-word !important;
      overflow-wrap: break-word !important;

      /* Gradient and Color Application */
      {%- if section.settings.use_theme_colors -%}
        {%- comment -%} When theme colors are enabled, use global accent text gradient {%- endcomment -%}
        background: {{ settings.global_accent_text_gradient_dark }};
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-fill-color: transparent;
        display: inline-block !important;
        padding: 2px 4px !important;
        margin: -2px -4px !important;
        line-height: 1.3 !important;
      {%- elsif section.settings.use_accent_gradient and section.settings.accent_text_gradient != blank -%}
        {%- comment -%} Use section-specific gradient when theme colors are off {%- endcomment -%}
        background: {{ section.settings.accent_text_gradient }};
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-fill-color: transparent;
        display: inline-block !important;
        padding: 2px 4px !important;
        margin: -2px -4px !important;
        line-height: 1.3 !important;
      {%- else -%}
        {%- comment -%} Use solid color as fallback {%- endcomment -%}
        color: {{ section.settings.heading_accent_color | default: '#ef4a65' }};
      {%- endif -%}
    }

    /* Fallback solid color for accent text when gradient is not used */
    .custom-hero .section-accent-text:not(:has(> .gradient-text)),
    .new-hero-accent-text:not(:has(> .gradient-text)) {
      color: {{ section.settings.heading_accent_color | default: '#ef4a65' }} !important;
    }

    .custom-hero__benefits {
      text-align: {{ section.settings.desktop_content_alignment }};
      {% if section.settings.desktop_content_alignment == 'center' %}
        padding-right: 0;
      {% endif %}
      {% if section.settings.benefits_flex_layout %}
        display: flex;
        flex-wrap: wrap;
        gap: 0px 5px;
        justify-content: {% if section.settings.desktop_content_alignment == 'center' %}center{% elsif section.settings.desktop_content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
      {% endif %}
    }

    /* Mobile specific flex layout adjustments */
    @media screen and (max-width: 768px) {
      .custom-hero__benefits.flex-layout {
        {% if section.settings.benefits_flex_layout %}
          gap: 0px 5px;
          justify-content: {% if section.settings.mobile_content_alignment == 'center' %}center{% elsif section.settings.mobile_content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
        {% endif %}
      }
    }

    .custom-hero .custom-hero__benefit-item {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.benefit_text_color }}{% endif %};
      font-size: {{ section.settings.benefit_font_size }}px !important;
      {% if section.settings.desktop_content_alignment == 'center' %}
        justify-content: center;
      {% elsif section.settings.desktop_content_alignment == 'right' %}
        justify-content: flex-end;
      {% else %}
        justify-content: flex-start;
      {% endif %}
    }

    .custom-hero .custom-hero__benefit-icon {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.benefit_icon_color }}{% endif %};
      font-size: {{ section.settings.benefit_icon_size }}px !important;
    }

    .custom-hero .custom-hero__benefit-icon svg {
      width: {{ section.settings.benefit_icon_size }}px !important;
      height: {{ section.settings.benefit_icon_size }}px !important;
    }

    .custom-hero .custom-hero__button {
      display: inline-block;
      width: 100% !important;
      /* Always use global spacing and consistency */
      padding: var(--global-button-padding-y, 12px) 20px !important;
      letter-spacing: var(--global-button-letter-spacing, 1px) !important;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none !important;
      text-align: center;
      box-shadow: none !important;
      
      {% if settings.enable_global_button_styling and section.settings.use_global_button_styling %}
        /* Use Global Button Styling (colors, typography, borders) */
        font-size: var(--global-button-font-size, 14px) !important;
        font-weight: var(--global-button-font-weight, 700) !important;
        text-transform: var(--global-button-text-transform, none) !important;
        border-radius: var(--global-button-radius, 8px) !important;
        background-color: var(--global-button-bg-color, #EF4A65) !important;
        color: var(--global-button-text-color, #FFFFFF) !important;
        border: var(--global-button-border-width, 0px) solid var(--global-button-border-color, #EF4A65) !important;
      {% else %}
        /* Use Custom Section Colors (but keep global spacing) */
      background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.button_bg }}{% endif %};
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.button_text_color }}{% endif %};
      font-size: {{ section.settings.button_font_size }}px !important;
        border: none;
      {% endif %}
    }

    .custom-hero .custom-hero__button:hover {
      {% if settings.enable_global_button_styling and section.settings.use_global_button_styling %}
        /* Global Button Hover State */
        background-color: var(--global-button-hover-bg-color, #D63953) !important;
        color: var(--global-button-hover-text-color, #FFFFFF) !important;
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
      {% else %}
        /* Custom Section Hover State */
        opacity: 0.9;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      {% endif %}
    }

    .custom-hero .custom-hero__review-count {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.rating_text_color }}{% endif %};
    }

    .custom-hero .custom-hero__guarantee-icon {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.benefit_icon_color }}{% endif %};
      font-size: {{ section.settings.guarantee_icon_size }}px !important;
    }

    .custom-hero .custom-hero__guarantee-text {
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.benefit_text_color }}{% endif %};
      font-size: {{ section.settings.guarantee_font_size }}px !important;
    }

    .custom-hero .custom-hero__guarantee {
      width: 100% !important;
      text-align: center;
    }

    @media (max-width: 768px) {
      .custom-hero__flex {
        gap: {% if section.settings.fit_image_to_height %}0{% else %}20px{% endif %};
      }

      {% if section.settings.fit_image_to_height %}
      .custom-hero__image-wrapper {
        aspect-ratio: 1;
        height: auto;
      }

      .custom-hero__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      {% endif %}
      
      {% if section.settings.enable_image_fade_mask %}
        .custom-hero__image-wrapper {
          -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
          mask-image: linear-gradient(to top, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 20%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,1) 70%);
        }
      {% endif %}
      
      .custom-hero .custom-hero__title {
        font-family: var(--font-heading-family) !important;
        font-weight: var(--font-weight-bold) !important;
        font-size: {{ section.settings.heading_size_mobile }}px !important;
        line-height: {{ section.settings.heading_line_height_mobile }};
        /* Ensure proper text flow and prevent cutoff on mobile */
        overflow: visible !important;
        word-wrap: break-word !important;
        overflow-wrap: break-word !important;
        margin-bottom: {{ section.settings.header_margin_bottom_mobile | default: 15 }}px !important;
      }
      
      .custom-hero .custom-hero__badge,
      section.custom-hero .custom-hero__badge,
      .custom-hero .custom-hero__badge-wrapper .custom-hero__badge {
        font-size: {{ section.settings.badge_font_size_mobile }}px !important;
      }
      
      .custom-hero__benefits {
        text-align: {{ section.settings.mobile_content_alignment }};
        {% if section.settings.mobile_content_alignment == 'center' %}
          padding-right: 0;
        {% endif %}
      }

      .custom-hero .custom-hero__benefit-item {
        font-size: {{ section.settings.benefit_font_size_mobile }}px !important;
        {% if section.settings.mobile_content_alignment == 'center' %}
          justify-content: center;
        {% elsif section.settings.mobile_content_alignment == 'right' %}
          justify-content: flex-end;
        {% else %}
          justify-content: flex-start;
        {% endif %}
      }
      
      .custom-hero .custom-hero__benefit-icon svg {
        width: {{ section.settings.benefit_icon_size }}px !important;
        height: {{ section.settings.benefit_icon_size }}px !important;
      }

      /* Mobile custom SVG styling */
      .custom-hero__guarantee-icon svg {
        width: {{ section.settings.guarantee_icon_size }}px !important;
        height: {{ section.settings.guarantee_icon_size }}px !important;
        fill: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.benefit_icon_color }}{% endif %};
      }
      
      .custom-hero .custom-hero__button {
        {% unless settings.enable_global_button_styling and section.settings.use_global_button_styling %}
        font-size: {{ section.settings.button_font_size_mobile }}px !important;
        {% endunless %}
      }
      
      .custom-hero .custom-hero__guarantee-text {
        font-size: {{ section.settings.guarantee_font_size_mobile }}px !important;
      }
    }

    .custom-hero .custom-hero__subtitle {
      font-size: {{ section.settings.subtitle_font_size_mobile }}px !important;
      line-height: {{ section.settings.subtitle_line_height }}em !important;
      margin-top: {{ section.settings.subtitle_margin_top_mobile }}px !important;
      margin-bottom: {{ section.settings.subtitle_margin_bottom_mobile }}px !important;
    }

    .custom-hero .custom-hero__badge,
    .custom-hero .custom-hero__badge-wrapper {
      {% if section.settings.mobile_content_alignment == 'center' %}
        text-align: center;
      {% elsif section.settings.mobile_content_alignment == 'right' %}
        text-align: right;
      {% else %}
        text-align: left;
      {% endif %}
    }
    
    .custom-hero__benefits {
      {% if section.settings.mobile_content_alignment == 'center' %}
        text-align: center;
      {% elsif section.settings.mobile_content_alignment == 'right' %}
        text-align: right;
      {% else %}
        text-align: left;
      {% endif %}
    }

    /* Badge alignment based on mobile content alignment */
    @media screen and (max-width: 768px) {
      .custom-hero .custom-hero__badge-wrapper {
        text-align: {{ section.settings.mobile_content_alignment }};
      }
      
      .custom-hero__benefits.flex-layout {
        {% if section.settings.benefits_flex_layout %}
          display: flex;
          flex-wrap: wrap;
          gap: 0px 5px;
          justify-content: {% if section.settings.mobile_content_alignment == 'center' %}center{% elsif section.settings.mobile_content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
        {% endif %}
      }
    }



    /* Reset paragraph margins within subtitle on mobile */
    .custom-hero .custom-hero__subtitle p {
      margin: 0 !important;
      padding: 0 !important;
    }
{% endstyle %}
