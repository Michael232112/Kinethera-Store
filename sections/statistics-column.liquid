{{ 'statistics-column.css' | asset_url | stylesheet_tag }}

<style>
  .section-{{ section.id }} {
    --stats-padding-top: {{ section.settings.padding_top }}px;
    --stats-padding-bottom: {{ section.settings.padding_bottom }}px;
    --stats-number-size-mobile: {{ section.settings.number_size_mobile }}px;
    --stats-number-size-desktop: {{ section.settings.number_size_desktop }}px;
    --stats-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --stats-title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --stats-description-size-mobile: {{ section.settings.description_size_mobile }}px;
    --stats-description-size-desktop: {{ section.settings.description_size_desktop }}px;
    --stats-disclaimer-padding-top: {{ section.settings.disclaimer_padding_top }}px;
    --stats-disclaimer-padding-bottom: {{ section.settings.disclaimer_padding_bottom }}px;
    --stats-disclaimer-padding-left: {{ section.settings.disclaimer_padding_left }}px;
    --stats-disclaimer-padding-right: {{ section.settings.disclaimer_padding_right }}px;
    --stats-disclaimer-size-mobile: {{ section.settings.disclaimer_size_mobile }}px;
    --stats-disclaimer-size-desktop: {{ section.settings.disclaimer_size_desktop }}px;
    --stats-disclaimer-border-radius: {{ section.settings.disclaimer_border_radius }}px;
    --stats-disclaimer-background: {{ section.settings.disclaimer_background_color }};
    --stats-disclaimer-color: {{ section.settings.disclaimer_color }};
    --stats-disclaimer-icon-color: {{ section.settings.disclaimer_icon_color }};
    --stats-disclaimer-line-height: {{ section.settings.disclaimer_line_height }};
    --stats-disclaimer-border-width: {{ section.settings.disclaimer_border_width }}px;
    --stats-disclaimer-border-style: {{ section.settings.disclaimer_border_style }};
    --stats-disclaimer-border-color: {{ section.settings.disclaimer_border_color }};
    padding-top: var(--stats-padding-top);
    padding-bottom: var(--stats-padding-bottom);
  }



  .section-{{ section.id }} .stats-column-title {
    font-size: var(--stats-title-size-mobile);
    color: {{ section.settings.title_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .stats-column-title {
      font-size: var(--stats-title-size-desktop);
    }
  }

  .section-{{ section.id }} .stats-column-description {
    font-size: var(--stats-description-size-mobile);
    color: {{ section.settings.description_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .stats-column-description {
      font-size: var(--stats-description-size-desktop);
    }
  }



  .section-{{ section.id }} .studies-disclaimer {
    margin-top: 2rem;
  }

  .section-{{ section.id }} .studies-disclaimer-content {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: var(--stats-disclaimer-padding-top) var(--stats-disclaimer-padding-right) var(--stats-disclaimer-padding-bottom) var(--stats-disclaimer-padding-left);
    background-color: {% if use_theme_colors %}color-mix(in srgb, {{ settings.global_section_text_color }} 5%, transparent){% else %}var(--stats-disclaimer-background){% endif %};
    border-radius: var(--stats-disclaimer-border-radius);
    border: var(--stats-disclaimer-border-width) var(--stats-disclaimer-border-style) {% if use_theme_colors %}color-mix(in srgb, {{ settings.global_section_text_color }} 20%, transparent){% else %}var(--stats-disclaimer-border-color){% endif %};
  }

  .section-{{ section.id }} .disclaimer-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
    opacity: 0.7;
    color: var(--stats-disclaimer-icon-color);
  }

  .section-{{ section.id }} .disclaimer-icon svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .section-{{ section.id }} .studies-disclaimer-text {
    font-weight: var(--font-weight-regular);
    margin: 0;
    line-height: var(--stats-disclaimer-line-height);
    letter-spacing: var(--letter-spacing-body);
    flex: 1;
    font-size: var(--stats-disclaimer-size-mobile);
    color: var(--stats-disclaimer-color);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .studies-disclaimer-text {
      font-size: var(--stats-disclaimer-size-desktop);
    }
  }

  .section-{{ section.id }} .studies-disclaimer-text strong {
    color: var(--stats-disclaimer-icon-color);
  }
</style>

{% comment %} Google Fonts for accent text customization {% endcomment %}
{% if section.settings.override_global_accent %}
  {% if section.settings.accent_font_family != 'inherit' and section.settings.accent_font_family != 'serif' %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {% case section.settings.accent_font_family %}
      {% when 'Georgia Pro' %}
        <link href="https://fonts.googleapis.com/css2?family=Georgia+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
      {% when 'Bodoni Moda' %}
        <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;0,6..96,700;0,6..96,800;1,6..96,400;1,6..96,500;1,6..96,600;1,6..96,700;1,6..96,800&display=swap" rel="stylesheet">
      {% when 'Instrument Serif' %}
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
      {% when 'DM Serif Text' %}
        <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Text:ital@0;1&display=swap" rel="stylesheet">
      {% when 'Nothing You Could Do' %}
        <link href="https://fonts.googleapis.com/css2?family=Nothing+You+Could+Do&display=swap" rel="stylesheet">
    {% endcase %}
  {% endif %}
{% endif %}

{% assign use_theme_colors = section.settings.use_theme_colors %}

{%- style -%}
  .statistics-section-custom-background-{{ section.id }} {
    background: {{ section.settings.section_background | default: '#FFFFFF' }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .stats-column {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .stats-column-content {
    flex: 1;
    {% if section.settings.image_position_mobile == 'below' %}
      order: 1;
    {% else %}
      order: 2;
    {% endif %}
  }

  .stats-column-image {
    flex: 1;
    width: 100%;
    {% if section.settings.image_position_mobile == 'below' %}
      order: 2;
    {% else %}
      order: 1;
    {% endif %}
  }

  @media screen and (min-width: 990px) {
    .stats-column {
      {% if section.settings.image_position_desktop == 'above' %}
        flex-direction: column;
        gap: 2rem;
      {% else %}
        flex-direction: row;
        align-items: center;
        gap: 4rem;
      {% endif %}
    }

    .stats-column-content {
      {% if section.settings.image_position_desktop == 'above' %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
    }

    .stats-column-image {
      {% if section.settings.image_position_desktop == 'above' %}
        order: 1;
        max-width: 100%;
        margin-bottom: 2rem;
      {% else %}
        order: 2;
        max-width: 50%;
        margin-bottom: 0;
      {% endif %}
    }
  }

  .stats-column-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .stats-column-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media screen and (max-width: 749px) {
    .stats-column-list {
      margin: 0;
      padding: 0;
      width: 100%;
    }
  }

  .stats-column-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .stats-column-item {
      flex-direction: row;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 2rem;
      padding: 1.5rem 0;
      max-height: 150px;
      margin: 0;
      width: 100%;
    }
  }

  .stats-column-item:not(:last-child) {
    border-bottom: 1px solid {% if use_theme_colors %}color-mix(in srgb, {{ settings.global_section_text_color }} 20%, transparent){% else %}{{ section.settings.divider_color | default: '#e0e0e0' }}{% endif %};
  }

  .section-{{ section.id }} .stats-column-number {
    font-size: {{ section.settings.number_size_mobile }}px !important;
    font-weight: var(--font-weight-bold) !important;
    {% if use_theme_colors %}
      background: {{ settings.global_accent_text_gradient_light }} !important;
      background-image: {{ settings.global_accent_text_gradient_light }} !important;
      -webkit-background-clip: text !important;
      -moz-background-clip: text !important;
      background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      -moz-text-fill-color: transparent !important;
      color: transparent !important;
    {% elsif section.settings.number_gradient != blank %}
      background: {{ section.settings.number_gradient }} !important;
      background-image: {{ section.settings.number_gradient }} !important;
      -webkit-background-clip: text !important;
      -moz-background-clip: text !important;
      background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      -moz-text-fill-color: transparent !important;
      color: transparent !important;
    {% else %}
      color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.number_color }}{% endif %} !important;
    {% endif %}
    line-height: 1;
    flex-shrink: 0;
    min-width: 4rem;
    letter-spacing: var(--letter-spacing-body);
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .stats-column-number {
      font-size: {{ section.settings.number_size_mobile | plus: 16 }}px !important;
      min-width: 6rem;
      text-align: left;
      margin: 0;
      padding: 0;
      {% if use_theme_colors %}
        background: {{ settings.global_accent_text_gradient_light }} !important;
        background-image: {{ settings.global_accent_text_gradient_light }} !important;
        -webkit-background-clip: text !important;
        -moz-background-clip: text !important;
        background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        -moz-text-fill-color: transparent !important;
        color: transparent !important;
      {% elsif section.settings.number_gradient != blank %}
        background: {{ section.settings.number_gradient }} !important;
        background-image: {{ section.settings.number_gradient }} !important;
        -webkit-background-clip: text !important;
        -moz-background-clip: text !important;
        background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        -moz-text-fill-color: transparent !important;
        color: transparent !important;
      {% else %}
        color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.number_color }}{% endif %} !important;
      {% endif %}
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .stats-column-number {
      font-size: {{ section.settings.number_size_desktop }}px !important;
      min-width: 6rem;
      {% if use_theme_colors %}
        background: {{ settings.global_accent_text_gradient_light }} !important;
        background-image: {{ settings.global_accent_text_gradient_light }} !important;
        -webkit-background-clip: text !important;
        -moz-background-clip: text !important;
        background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        -moz-text-fill-color: transparent !important;
        color: transparent !important;
      {% elsif section.settings.number_gradient != blank %}
        background: {{ section.settings.number_gradient }} !important;
        background-image: {{ section.settings.number_gradient }} !important;
        -webkit-background-clip: text !important;
        -moz-background-clip: text !important;
        background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        -moz-text-fill-color: transparent !important;
        color: transparent !important;
      {% else %}
        color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.number_color }}{% endif %} !important;
      {% endif %}
    }
  }

  .stats-column-text {
    flex: 1;
    text-align: left;
  }

  @media screen and (max-width: 749px) {
    .stats-column-text {
      width: auto;
      flex: 1;
      margin: 0;
      padding: 0;
    }
  }

  .stats-column-title {
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: var(--font-weight-semibold);
    color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.title_color }}{% endif %} !important;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
    letter-spacing: var(--letter-spacing-body);
  }

  @media screen and (max-width: 749px) {
    .stats-column-title {
      font-size: {{ section.settings.title_size_mobile | plus: 0 }}px;
      color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.title_color }}{% endif %} !important;
      margin: 0 0 0.5rem 0;
    }
  }

  @media screen and (min-width: 750px) {
    .stats-column-title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }
  }

  .stats-column-description {
    font-size: {{ section.settings.description_size_mobile }}px;
    font-weight: var(--font-weight-regular);
    color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.description_color }}{% endif %} !important;
    margin: 0;
    line-height: 1.4;
    letter-spacing: var(--letter-spacing-body);
  }

  @media screen and (max-width: 749px) {
    .stats-column-description {
      font-size: {{ section.settings.description_size_mobile | plus: 0 }}px;
      color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.description_color }}{% endif %} !important;
      line-height: 1.5;
      margin: 0;
    }
  }

  @media screen and (min-width: 750px) {
    .stats-column-description {
      font-size: {{ section.settings.description_size_desktop }}px;
      color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.description_color }}{% endif %} !important;
    }
  }

  .stats-column-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  /* Mobile Header - visible on mobile, hidden on desktop */
  .stats-column-section-header.mobile-header {
    display: block;
  }

  /* Desktop Header - hidden on mobile, visible on desktop */
  .stats-column-section-header.desktop-header {
    display: none;
  }

  @media screen and (min-width: 990px) {
    .stats-column-section-header.mobile-header {
      display: none;
    }
    
    .stats-column-section-header.desktop-header {
      display: block;
    }
  }

  .section-{{ section.id }} .section-subtitle-container {
    width: 100%;
    text-align: center;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .section-{{ section.id }} .stats-section-title {
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: var(--font-weight-bold);
    color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.heading_color }}{% endif %} !important;
    margin: 0 0 1rem 0;
    letter-spacing: var(--letter-spacing-heading);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .stats-section-title {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }

  .section-{{ section.id }} .section-subtitle {
    font-size: {{ section.settings.subtitle_size_mobile }}px;
    font-weight: var(--font-weight-regular);
    color: {% if use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.subtitle_color }}{% endif %} !important;
    margin: 0;
    letter-spacing: var(--letter-spacing-body);
    text-align: center !important;
    width: 100%;
    max-width: 800px;
  }

  .section-{{ section.id }} .section-subtitle p {
    margin: 0;
    text-align: center !important;
    font-size: inherit;
    color: inherit;
    font-weight: inherit;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .section-subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }
  }



  /* Enhanced accent text styling with global and local customization options */
  .section-{{ section.id }} .stats-section-title .global-accent-text,
  .section-{{ section.id }} .stats-section-title .custom-accent-text {
    {% comment %} Always apply core accent text styling {% endcomment %}
    margin-left: {{ section.settings.accent_text_margin_left }}px !important;
    
    {% comment %} Check for theme colors first - use global light gradient when enabled {% endcomment %}
    {% if use_theme_colors %}
      background: {{ settings.global_accent_text_gradient_light }} !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
      color: transparent !important;
      display: inline-block !important;
      padding: 2px 4px !important;
      margin: -2px -4px !important;
      line-height: 1.3 !important;
    {% elsif section.settings.use_accent_gradient %}
      background: {{ section.settings.accent_text_gradient }} !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
      color: transparent !important;
      display: inline-block !important;
      padding: 2px 4px !important;
      margin: -2px -4px !important;
      line-height: 1.3 !important;
    {% else %}
      {% comment %} Apply solid color {% endcomment %}
      color: {{ section.settings.accent_color }} !important;
    {% endif %}
    
    {% if section.settings.override_global_accent %}
      {% comment %} Use section-specific typography settings when override is enabled {% endcomment %}
      {% if section.settings.accent_font_family != 'inherit' %}
        {% case section.settings.accent_font_family %}
          {% when 'serif' %}
            font-family: serif !important;
          {% when 'Georgia Pro' %}
            font-family: 'Georgia Pro', Georgia, serif !important;
          {% when 'Bodoni Moda' %}
            font-family: 'Bodoni Moda', Georgia, serif !important;
          {% when 'Instrument Serif' %}
            font-family: 'Instrument Serif', Georgia, serif !important;
          {% when 'DM Serif Text' %}
            font-family: 'DM Serif Text', Georgia, serif !important;
          {% when 'Nothing You Could Do' %}
            font-family: 'Nothing You Could Do', cursive !important;
        {% endcase %}
      {% else %}
        font-family: var(--font-accent-family, var(--font-body-family)) !important;
      {% endif %}
      
      font-style: {% if section.settings.accent_font_style != 'normal' %}{{ section.settings.accent_font_style }}{% else %}var(--font-accent-style, normal){% endif %} !important;
      font-weight: {% if section.settings.accent_font_weight != 'inherit' %}{{ section.settings.accent_font_weight }}{% else %}var(--font-accent-weight, inherit){% endif %} !important;
      
    {% else %}
      {% comment %} Use global accent typography system {% endcomment %}
      font-family: var(--font-accent-family, var(--font-body-family)) !important;
      font-style: var(--font-accent-style, normal) !important;
      font-weight: var(--font-accent-weight, inherit) !important;
      letter-spacing: var(--font-accent-letter-spacing, inherit) !important;
      text-transform: var(--font-accent-text-transform, none) !important;
    {% endif %}
  }

  /* Theme background styling */
  .statistics-section-theme-background-{{ section.id }} {
    background-color: {{ settings.global_section_text_color }} !important;
  }
{%- endstyle -%}

<div class="section-{{ section.id }} {% if use_theme_colors == false %}statistics-section-custom-background-{{ section.id }}{% else %}statistics-section-theme-background-{{ section.id }}{% endif %} stats-column-section">
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      <!-- Mobile Header -->
      {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
        <div class="stats-column-section-header mobile-header">
          {%- if section.settings.heading != blank -%}
            {% if section.settings.heading_accent != blank %}
              <h2 class="stats-section-title">
                {{ section.settings.heading }} 
                <span class="{% if section.settings.override_global_accent %}custom-accent-text{% else %}global-accent-text{% endif %}">
                  {{ section.settings.heading_accent }}
                </span>
              </h2>
            {% else %}
              <h2 class="stats-section-title">{{ section.settings.heading }}</h2>
            {% endif %}
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <div class="section-subtitle-container">
              <div class="section-subtitle">{{ section.settings.subtitle }}</div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="stats-column">
        <div class="stats-column-content">
          <!-- Desktop Header (inside stats-column-content) -->
          {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
            <div class="stats-column-section-header desktop-header">
              {%- if section.settings.heading != blank -%}
                {% if section.settings.heading_accent != blank %}
                  <h2 class="stats-section-title">
                    {{ section.settings.heading }} 
                    <span class="{% if section.settings.override_global_accent %}custom-accent-text{% else %}global-accent-text{% endif %}">
                      {{ section.settings.heading_accent }}
                    </span>
                  </h2>
                {% else %}
                  <h2 class="stats-section-title">{{ section.settings.heading }}</h2>
                {% endif %}
              {%- endif -%}
              {%- if section.settings.subtitle != blank -%}
                <div class="section-subtitle-container">
                  <div class="section-subtitle">{{ section.settings.subtitle }}</div>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
          
          <div class="stats-column-list">
            {%- for block in section.blocks -%}
              <div class="stats-column-item" {{ block.shopify_attributes }}>
                <div class="stats-column-number">{{ block.settings.number }}</div>
                <div class="stats-column-text">
                  {%- if block.settings.title != blank -%}
                    <h3 class="stats-column-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="stats-column-description">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- if section.settings.disclaimer_text != blank and section.settings.show_disclaimer -%}
            <div class="studies-disclaimer">
              <div class="studies-disclaimer-content">
                <div class="disclaimer-icon">
                  <svg fill="currentColor" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
                       width="16" height="16" viewBox="0 0 416.979 416.979">
                    <path d="M356.004,61.156c-81.37-81.47-213.377-81.551-294.848-0.182c-81.47,81.371-81.552,213.379-0.181,294.85
                      c81.369,81.47,213.378,81.551,294.849,0.181C437.293,274.636,437.375,142.626,356.004,61.156z M237.6,340.786
