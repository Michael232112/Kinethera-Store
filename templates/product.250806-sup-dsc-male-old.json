    "store_faq_Lpd3PW": {
      "type": "store-faq",
      "blocks": {
        "faq_item_YYJUL8": {
          "type": "faq_item",
          "settings": {
            "question": "How long before I see results?",
            "answer": "<p>Most people notice the difference by week 2, but week 4 is when you'll feel like you have a \"best.\" <br/>Many of our customers reported improved comfort with regular use when other wellness routines hadn't delivered.</p>"
          }
        },
        "faq_item_QKVnRn": {
          "type": "faq_item",
          "settings": {
            "question": "How should I take for best results?",
            "answer": "<p>Take 2 capsules daily with food (morning and evening work best). Consistency matters more than timing — your body needs 3-4 weeks of consistent use to feel the difference.</p>"
          }
        },
        "faq_item_appL6A": {
          "type": "faq_item",
          "settings": {
            "question": "Is Advanced Recovery Complex safe for long-term use?",
            "answer": "<p>Advanced Recovery Complex contains ingredients designed to complement your body's natural processes and support your daily wellness routine. 365-day money-back guarantee.</p>"
          }
        },
        "faq_item_fMQrU3": {
          "type": "faq_item",
          "settings": {
            "question": "Oral vs Injections: why capsules work better?",
            "answer": "<p>Our oral capsules are designed to support your overall daily wellness, taken conveniently with your morning and evening meals. Supporting your gut comfort as part of your daily routine, then promoting overall comfort and wellness throughout your body. No needles, no hassle.</p>"
          }
        },
        "faq_item_ULG8UQ": {
          "type": "faq_item",
          "settings": {
            "question": "Why hasn't your doctor told you about Advanced Recovery Complex?",
            "answer": "<p>Advanced Recovery Complex is formulated with quality ingredients designed to support your daily wellness routine. We focus on ingredient quality, transparent labeling, and your satisfaction above all else.</p>"
          }
        },
        "faq_item_7RLBwn": {
          "type": "faq_item",
          "settings": {
            "question": "How long do I have to wait for delivery?",
            "answer": "<p>Order now and get your product delivered to <br/>your doorstep in 5-12 business days. Worldwide, tracked, and insured shipping on every order.</p>"
          }
        }
      },
