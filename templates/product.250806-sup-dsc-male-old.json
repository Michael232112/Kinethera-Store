          "settings": {
            "show_stars": true,
            "title": "Simple to take, fits my lifestyle perfectly.",
            "content": "<p>\"Simple to take, fits my lifestyle perfectly. Easy to incorporate into my morning routine. I would recommend this to anyone looking for a quality supplement. Highly recommend.\"</p>",
